{
  "uid": "futurekawa-overview",
  "title": "FutureKawa Overview",
  "tags": ["futurekawa", "prometheus", "alerts"],
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "30s",
  "editable": true,
  "templating": {
    "list": [
      {
        "type": "query",
        "name": "job",
        "label": "Job",
        "datasource": { "type": "prometheus", "uid": "prometheus" },
        "query": "label_values(up, job)",
        "includeAll": true,
        "multi": true,
        "allValue": ".*",
        "refresh": 1,
        "sort": 1
      }
    ]
  },
  "time": { "from": "now-6h", "to": "now" },
  "annotations": { "list": [] },
  "links": [],
  "panels": [
    {
      "type": "stat",
      "title": "CPU système",
      "gridPos": { "h": 8, "w": 6, "x": 0, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "refId": "A",
          "expr": "avg by (job) (system_cpu_usage{job=~\"$job\"})"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "decimals": 2,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "orange", "value": 0.6 },
              { "color": "red", "value": 0.8 }
            ]
          }
        },
        "overrides": []
      }
    },
    {
      "type": "stat",
      "title": "Mémoire heap utilisée",
      "gridPos": { "h": 8, "w": 6, "x": 6, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "refId": "A",
          "expr": "sum by (job) (jvm_memory_used_bytes{area=\"heap\",job=~\"$job\"})"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "bytes", "decimals": 0 },
        "overrides": []
      }
    },
    {
      "type": "stat",
      "title": "Threads actives",
      "gridPos": { "h": 8, "w": 6, "x": 12, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "refId": "A",
          "expr": "avg by (job) (jvm_threads_live_threads{job=~\"$job\"})"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "short", "decimals": 0 },
        "overrides": []
      }
    },
    {
      "type": "timeseries",
      "title": "Requêtes HTTP / s",
      "gridPos": { "h": 10, "w": 12, "x": 0, "y": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "refId": "A",
          "expr": "sum by (job) (rate(http_server_requests_seconds_count{job=~\"$job\"}[5m]))"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "reqps", "decimals": 2 },
        "overrides": []
      }
    },
    {
      "type": "timeseries",
      "title": "Réponses HTTP par statut",
      "gridPos": { "h": 10, "w": 12, "x": 12, "y": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "refId": "A",
          "expr": "sum by (job, status) (rate(http_server_requests_seconds_count{job=~\"$job\"}[5m]))"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "reqps", "decimals": 2 },
        "overrides": []
      }
    },
    {
      "type": "timeseries",
      "title": "Latence HTTP max",
      "gridPos": { "h": 10, "w": 24, "x": 0, "y": 18 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "refId": "A",
          "expr": "max by (job) (http_server_requests_seconds_max{job=~\"$job\"})"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "s", "decimals": 3 },
        "overrides": []
      }
    }
  ]
}
